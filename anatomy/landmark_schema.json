{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BiometricLandmarkArtifact",
  "description": "Ground truth artifact schema for facial biometric landmark annotations",
  "type": "object",
  "required": ["artifact_id", "source", "landmarks", "metadata"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "description": "Unique identifier for this GTA (UUID v4)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "schema_version": {
      "type": "string",
      "description": "Schema version for forward compatibility",
      "default": "1.0.0"
    },
    "source": {
      "type": "object",
      "description": "Image source metadata (no raw image data stored here)",
      "required": ["image_hash", "capture_timestamp", "resolution"],
      "properties": {
        "image_hash": {
          "type": "string",
          "description": "SHA-256 hash of the EXIF-stripped source image"
        },
        "capture_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp of image capture"
        },
        "resolution": {
          "type": "object",
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "sensor_id": {
          "type": "string",
          "description": "Anonymized sensor/device identifier"
        }
      }
    },
    "landmarks": {
      "type": "object",
      "description": "Validated landmark coordinates from MediaPipe FaceMesh (478 points)",
      "required": ["face_mesh", "confidence", "validator"],
      "properties": {
        "face_mesh": {
          "type": "array",
          "description": "Normalized landmark coordinates [x, y, z] in image space (0.0–1.0)",
          "minItems": 1,
          "maxItems": 478,
          "items": {
            "type": "object",
            "required": ["index", "x", "y", "z"],
            "properties": {
              "index": { "type": "integer", "minimum": 0, "maximum": 477 },
              "x": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "y": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "z": { "type": "number", "description": "Depth relative to face center" },
              "visibility": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          }
        },
        "confidence": {
          "type": "number",
          "description": "Overall detection confidence score from MediaPipe",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "validator": {
          "type": "string",
          "description": "MediaPipe model used for validation",
          "enum": ["face_mesh_v1", "face_landmarker_v2"]
        },
        "bounding_box": {
          "type": "object",
          "description": "Face bounding box in normalized coordinates",
          "properties": {
            "x_min": { "type": "number", "minimum": 0.0 },
            "y_min": { "type": "number", "minimum": 0.0 },
            "x_max": { "type": "number", "maximum": 1.0 },
            "y_max": { "type": "number", "maximum": 1.0 }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["created_at", "pipeline_version"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp when this artifact was generated"
        },
        "pipeline_version": {
          "type": "string",
          "description": "Version of the GTA generation pipeline"
        },
        "quality_flags": {
          "type": "array",
          "description": "QA flags raised during processing",
          "items": {
            "type": "string",
            "enum": [
              "low_confidence",
              "partial_occlusion",
              "lighting_variance",
              "pose_deviation",
              "exif_present_stripped",
                              "face_crop_used",
                              "multiple_faces_detected"
            ]
          }
        },
        "approved": {
          "type": "boolean",
          "description": "Whether this artifact has passed manual QA review"
        }
      }
    },
    "geometry": {
      "type": "object",
      "description": "Biometric facial measurements derived from landmark coordinates (offline, no image required). All linear measurements normalized by inter-ocular distance (IOD).",
      "properties": {
        "analyzer_version": { "type": "string" },
        "analyzed_at":      { "type": "string", "format": "date-time" },
        "iod_raw":          { "type": "number", "description": "Raw inter-ocular distance in normalized image coordinates" },
        "measurements": {
          "type": "object",
          "properties": {
            "eye_left_width_norm":       { "type": "number" },
            "eye_left_height_norm":      { "type": "number" },
            "eye_left_aspect_ratio":     { "type": "number" },
            "eye_right_width_norm":      { "type": "number" },
            "eye_right_height_norm":     { "type": "number" },
            "eye_right_aspect_ratio":    { "type": "number" },
            "eye_width_symmetry":        { "type": "number" },
            "eye_height_symmetry":       { "type": "number" },
            "iod_inner_canthal_norm":    { "type": "number" },
            "outer_canthal_dist_norm":   { "type": "number" },
            "canthal_index":             { "type": "number" },
            "eye_level_asymmetry_norm":  { "type": "number" },
            "canthal_tilt_left_deg":     { "type": "number" },
            "canthal_tilt_right_deg":    { "type": "number" },
            "brow_left_width_norm":      { "type": "number" },
            "brow_right_width_norm":     { "type": "number" },
            "brow_width_symmetry":       { "type": "number" },
            "brow_left_eye_gap_norm":    { "type": "number" },
            "brow_right_eye_gap_norm":   { "type": "number" },
            "brow_gap_symmetry":         { "type": "number" },
            "nose_width_norm":           { "type": "number" },
            "nose_length_norm":          { "type": "number" },
            "nose_bridge_length_norm":   { "type": "number" },
            "nasal_index":               { "type": "number", "description": "nose_width/nose_length * 100" },
            "nose_tip_deviation_norm":   { "type": "number" },
            "alar_to_iod_ratio":         { "type": "number" },
            "mouth_width_norm":          { "type": "number" },
            "mouth_to_iod_ratio":        { "type": "number" },
            "upper_lip_height_norm":     { "type": "number" },
            "lower_lip_height_norm":     { "type": "number" },
            "lip_ratio":                 { "type": "number" },
            "philtrum_length_norm":      { "type": "number" },
            "mouth_to_chin_norm":        { "type": "number" },
            "nose_to_mouth_norm":        { "type": "number" },
            "mouth_deviation_norm":      { "type": "number" },
            "face_width_norm":           { "type": "number" },
            "face_height_norm":          { "type": "number" },
            "jaw_width_norm":            { "type": "number" },
            "facial_index":              { "type": "number", "description": "face_height/face_width * 100" },
            "jaw_to_cheek_ratio":        { "type": "number" },
            "face_to_iod_ratio":         { "type": "number" },
            "facial_third_upper":        { "type": "number" },
            "facial_third_mid":          { "type": "number" },
            "facial_third_lower":        { "type": "number" },
            "symmetry_index":            { "type": "number", "description": "Mean asymmetry score; lower = more symmetric" }
          }
        }
      }
    },
    "body_pose": {
      "type": "object",
      "description": "Full-body pose landmarks from MediaPipe PoseLandmarker (33 3D points). Best-effort — head/shoulder images yield partial results.",
      "properties": {
        "landmarks": {
          "type": "array",
          "description": "33 BlazePose GHUM landmarks in normalized image coordinates",
          "minItems": 1,
          "maxItems": 33,
          "items": {
            "type": "object",
            "required": ["index", "name", "x", "y", "z", "visibility"],
            "properties": {
              "index":      { "type": "integer", "minimum": 0, "maximum": 32 },
              "name":       { "type": "string" },
              "x":          { "type": "number", "description": "Normalized x coordinate (0.0–1.0)" },
              "y":          { "type": "number", "description": "Normalized y coordinate (0.0–1.0)" },
              "z":          { "type": "number", "description": "Depth relative to hip midpoint" },
              "visibility": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          }
        },
        "confidence": {
          "type": "number",
          "description": "Mean landmark visibility across all 33 points",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "validator":      { "type": "string", "description": "MediaPipe model used", "enum": ["pose_landmarker_full"] },
        "landmark_count": { "type": "integer", "minimum": 1, "maximum": 33 },
        "coverage": {
          "type": "object",
          "description": "Which body regions have landmark visibility > 0.5",
          "properties": {
            "head":        { "type": "boolean" },
            "upper_body":  { "type": "boolean" },
            "arms":        { "type": "boolean" },
            "torso":       { "type": "boolean" },
            "lower_body":  { "type": "boolean" },
            "full_legs":   { "type": "boolean" },
            "feet":        { "type": "boolean" }
          }
        }
      }
    },
    "body_geometry": {
      "type": "object",
      "description": "Anthropometric measurements derived from body_pose landmarks. Linear measurements converted to cm via IOD calibration (population mean IOD = 63 mm). Circumferences are not derivable from single-view 2D pose and are not included.",
      "properties": {
        "analyzer_version": { "type": "string" },
        "analyzed_at":      { "type": "string", "format": "date-time" },
        "calibration": {
          "type": "object",
          "properties": {
            "method":             { "type": "string", "enum": ["iod_population_mean", "none"] },
            "iod_calibration_mm": { "type": "number", "description": "Population mean IOD used (63.0 mm)" },
            "cm_per_norm_unit":   { "type": "number", "description": "Derived scale factor" }
          }
        },
        "coverage": {
          "$ref": "#/properties/body_pose/properties/coverage"
        },
        "measurements": {
          "type": "object",
          "properties": {
            "shoulder_width_norm":      { "type": "number", "description": "Biacromial width in normalized image coordinates" },
            "shoulder_width_cm":        { "type": ["number", "null"] },
            "shoulder_width_note":      { "type": "string" },
            "hip_width_norm":           { "type": "number", "description": "Bi-iliac width in normalized image coordinates" },
            "hip_width_cm":             { "type": ["number", "null"] },
            "hip_width_note":           { "type": "string" },
            "waist_width_cm":           { "type": ["number", "null"], "description": "Estimated as 85% of shoulder width — requires multi-angle capture for accuracy" },
            "waist_width_note":         { "type": "string" },
            "chest_width_cm":           { "type": ["number", "null"], "description": "Estimated as 92% of shoulder width — breadth only, not circumference" },
            "chest_width_note":         { "type": "string" },
            "torso_length_norm":        { "type": "number" },
            "torso_length_cm":          { "type": ["number", "null"] },
            "upper_arm_left_cm":        { "type": ["number", "null"] },
            "upper_arm_right_cm":       { "type": ["number", "null"] },
            "lower_arm_left_cm":        { "type": ["number", "null"] },
            "lower_arm_right_cm":       { "type": ["number", "null"] },
            "arm_left_cm":              { "type": ["number", "null"] },
            "arm_right_cm":             { "type": ["number", "null"] },
            "arm_symmetry":             { "type": ["number", "null"], "description": "left/right arm length ratio; 1.0 = perfect symmetry" },
            "upper_leg_left_cm":        { "type": ["number", "null"] },
            "upper_leg_right_cm":       { "type": ["number", "null"] },
            "lower_leg_left_cm":        { "type": ["number", "null"] },
            "lower_leg_right_cm":       { "type": ["number", "null"] },
            "leg_left_cm":              { "type": ["number", "null"] },
            "leg_right_cm":             { "type": ["number", "null"] },
            "leg_symmetry":             { "type": ["number", "null"], "description": "left/right leg length ratio; 1.0 = perfect symmetry" },
            "height_cm":                { "type": ["number", "null"], "description": "Estimated full standing height. Accuracy ±5–10% from single frontal image." },
            "height_note":              { "type": "string" },
            "shoulder_to_hip_ratio":    { "type": ["number", "null"] },
            "torso_to_leg_ratio":       { "type": ["number", "null"] },
            "arm_to_leg_ratio":         { "type": ["number", "null"] },
            "upper_to_lower_arm_ratio": { "type": ["number", "null"] },
            "upper_to_lower_leg_ratio": { "type": ["number", "null"] },
            "shoulder_level_diff_cm":   { "type": ["number", "null"], "description": "Vertical shoulder asymmetry in cm; 0 = level" },
            "shoulder_level_diff_norm": { "type": ["number", "null"] },
            "hip_level_diff_norm":      { "type": ["number", "null"] },
            "hip_level_diff_cm":        { "type": ["number", "null"] },
            "trunk_lean_deg":           { "type": ["number", "null"], "description": "Lateral trunk lean angle in degrees; 0 = perfectly vertical" }
          }
        }
      }
    },
    "enrichment": {
      "type": "object",
      "description": "Optional Gemini-generated enrichment (forensic attributes + sartorial data)",
      "properties": {
        "model": { "type": "string", "description": "Gemini model used for enrichment" },
        "enriched_at": { "type": "string", "format": "date-time" },
        "forensic": {
          "type": "object",
          "description": "Forensic biometric attributes extracted by Gemini",
          "properties": {
            "face_shape":           { "type": "string" },
            "skin_tone":            { "type": "string" },
            "eye_color":            { "type": "string" },
            "hair_color":           { "type": "string" },
            "hair_length":          { "type": "string" },
            "hair_style":           { "type": "string" },
            "facial_hair":          { "type": "string" },
            "estimated_age_range":  { "type": "string" },
            "distinctive_features": { "type": "array", "items": { "type": "string" } },
            "eyewear":              { "type": "string" },
            "expression":           { "type": "string" }
          }
        },
        "sartorial": {
          "type": "object",
          "description": "Clothing and accessories observed by Gemini",
          "properties": {
            "top_garment":      { "type": "string" },
            "top_color":        { "type": "string" },
            "top_pattern":      { "type": "string" },
            "bottom_garment":   { "type": "string" },
            "bottom_color":     { "type": "string" },
            "outerwear":        { "type": "string" },
            "accessories":      { "type": "array", "items": { "type": "string" } },
            "footwear":         { "type": "string" },
            "style_category":   { "type": "string" },
            "notable_details":  { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
