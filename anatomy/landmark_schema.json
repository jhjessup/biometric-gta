{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BiometricLandmarkArtifact",
  "description": "Ground truth artifact schema for facial biometric landmark annotations",
  "type": "object",
  "required": ["artifact_id", "source", "landmarks", "metadata"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "description": "Unique identifier for this GTA (UUID v4)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "schema_version": {
      "type": "string",
      "description": "Schema version for forward compatibility",
      "default": "1.0.0"
    },
    "source": {
      "type": "object",
      "description": "Image source metadata (no raw image data stored here)",
      "required": ["image_hash", "capture_timestamp", "resolution"],
      "properties": {
        "image_hash": {
          "type": "string",
          "description": "SHA-256 hash of the EXIF-stripped source image"
        },
        "capture_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp of image capture"
        },
        "resolution": {
          "type": "object",
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "sensor_id": {
          "type": "string",
          "description": "Anonymized sensor/device identifier"
        }
      }
    },
    "landmarks": {
      "type": "object",
      "description": "Validated landmark coordinates from MediaPipe FaceMesh (478 points)",
      "required": ["face_mesh", "confidence", "validator"],
      "properties": {
        "face_mesh": {
          "type": "array",
          "description": "Normalized landmark coordinates [x, y, z] in image space (0.0–1.0)",
          "minItems": 1,
          "maxItems": 478,
          "items": {
            "type": "object",
            "required": ["index", "x", "y", "z"],
            "properties": {
              "index": { "type": "integer", "minimum": 0, "maximum": 477 },
              "x": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "y": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "z": { "type": "number", "description": "Depth relative to face center" },
              "visibility": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          }
        },
        "confidence": {
          "type": "number",
          "description": "Overall detection confidence score from MediaPipe",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "validator": {
          "type": "string",
          "description": "MediaPipe model used for validation",
          "enum": ["face_mesh_v1", "face_landmarker_v2"]
        },
        "bounding_box": {
          "type": "object",
          "description": "Face bounding box in normalized coordinates",
          "properties": {
            "x_min": { "type": "number", "minimum": 0.0 },
            "y_min": { "type": "number", "minimum": 0.0 },
            "x_max": { "type": "number", "maximum": 1.0 },
            "y_max": { "type": "number", "maximum": 1.0 }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["created_at", "pipeline_version"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp when this artifact was generated"
        },
        "pipeline_version": {
          "type": "string",
          "description": "Version of the GTA generation pipeline"
        },
        "quality_flags": {
          "type": "array",
          "description": "QA flags raised during processing",
          "items": {
            "type": "string",
            "enum": [
              "low_confidence",
              "partial_occlusion",
              "lighting_variance",
              "pose_deviation",
              "exif_present_stripped",
                              "face_crop_used",
                              "multiple_faces_detected"
            ]
          }
        },
        "approved": {
          "type": "boolean",
          "description": "Whether this artifact has passed manual QA review"
        }
      }
    },
    "geometry": {
      "type": "object",
      "description": "Biometric facial measurements derived from landmark coordinates (offline, no image required). All linear measurements normalized by inter-ocular distance (IOD).",
      "properties": {
        "analyzer_version": { "type": "string" },
        "analyzed_at":      { "type": "string", "format": "date-time" },
        "iod_raw":          { "type": "number", "description": "Raw inter-ocular distance in normalized image coordinates" },
        "measurements": {
          "type": "object",
          "properties": {
            "eye_left_width_norm":       { "type": "number" },
            "eye_left_height_norm":      { "type": "number" },
            "eye_left_aspect_ratio":     { "type": "number" },
            "eye_right_width_norm":      { "type": "number" },
            "eye_right_height_norm":     { "type": "number" },
            "eye_right_aspect_ratio":    { "type": "number" },
            "eye_width_symmetry":        { "type": "number" },
            "eye_height_symmetry":       { "type": "number" },
            "iod_inner_canthal_norm":    { "type": "number" },
            "outer_canthal_dist_norm":   { "type": "number" },
            "canthal_index":             { "type": "number" },
            "eye_level_asymmetry_norm":  { "type": "number" },
            "canthal_tilt_left_deg":     { "type": "number" },
            "canthal_tilt_right_deg":    { "type": "number" },
            "brow_left_width_norm":      { "type": "number" },
            "brow_right_width_norm":     { "type": "number" },
            "brow_width_symmetry":       { "type": "number" },
            "brow_left_eye_gap_norm":    { "type": "number" },
            "brow_right_eye_gap_norm":   { "type": "number" },
            "brow_gap_symmetry":         { "type": "number" },
            "nose_width_norm":           { "type": "number" },
            "nose_length_norm":          { "type": "number" },
            "nose_bridge_length_norm":   { "type": "number" },
            "nasal_index":               { "type": "number", "description": "nose_width/nose_length * 100" },
            "nose_tip_deviation_norm":   { "type": "number" },
            "alar_to_iod_ratio":         { "type": "number" },
            "mouth_width_norm":          { "type": "number" },
            "mouth_to_iod_ratio":        { "type": "number" },
            "upper_lip_height_norm":     { "type": "number" },
            "lower_lip_height_norm":     { "type": "number" },
            "lip_ratio":                 { "type": "number" },
            "philtrum_length_norm":      { "type": "number" },
            "mouth_to_chin_norm":        { "type": "number" },
            "nose_to_mouth_norm":        { "type": "number" },
            "mouth_deviation_norm":      { "type": "number" },
            "face_width_norm":           { "type": "number" },
            "face_height_norm":          { "type": "number" },
            "jaw_width_norm":            { "type": "number" },
            "facial_index":              { "type": "number", "description": "face_height/face_width * 100" },
            "jaw_to_cheek_ratio":        { "type": "number" },
            "face_to_iod_ratio":         { "type": "number" },
            "facial_third_upper":        { "type": "number" },
            "facial_third_mid":          { "type": "number" },
            "facial_third_lower":        { "type": "number" },
            "symmetry_index":            { "type": "number", "description": "Mean asymmetry score; lower = more symmetric" }
          }
        }
      }
    },
    "enrichment": {
      "type": "object",
      "description": "Optional Gemini-generated enrichment (forensic attributes + sartorial data)",
      "properties": {
        "model": { "type": "string", "description": "Gemini model used for enrichment" },
        "enriched_at": { "type": "string", "format": "date-time" },
        "forensic": {
          "type": "object",
          "description": "Forensic biometric attributes extracted by Gemini",
          "properties": {
            "face_shape":           { "type": "string" },
            "skin_tone":            { "type": "string" },
            "eye_color":            { "type": "string" },
            "hair_color":           { "type": "string" },
            "hair_length":          { "type": "string" },
            "hair_style":           { "type": "string" },
            "facial_hair":          { "type": "string" },
            "estimated_age_range":  { "type": "string" },
            "distinctive_features": { "type": "array", "items": { "type": "string" } },
            "eyewear":              { "type": "string" },
            "expression":           { "type": "string" }
          }
        },
        "sartorial": {
          "type": "object",
          "description": "Clothing and accessories observed by Gemini",
          "properties": {
            "top_garment":      { "type": "string" },
            "top_color":        { "type": "string" },
            "top_pattern":      { "type": "string" },
            "bottom_garment":   { "type": "string" },
            "bottom_color":     { "type": "string" },
            "outerwear":        { "type": "string" },
            "accessories":      { "type": "array", "items": { "type": "string" } },
            "footwear":         { "type": "string" },
            "style_category":   { "type": "string" },
            "notable_details":  { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
