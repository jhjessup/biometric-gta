# Copy to .env and fill in values. Never commit .env.
GTA_DATA_DIR=./data
GTA_OUTPUT_DIR=./output
GTA_LOG_LEVEL=INFO

# Required for Gemini enrichment (Tier 3 — agents/gemini_enricher.py)
GEMINI_API_KEY=

# InstantID generation server (notebooks/kaggle_instantid_server.ipynb → scripts/instantid_client.py)
# Start the Kaggle notebook, copy the printed trycloudflare.com URL here.
INSTANTID_SERVER_URL=

# Perchance (superseded by InstantID — kept for reference)
# Cloudflare Turnstile blocks headless browsers; use a solver service or provide a token manually.
# Option A: pre-solved token from browser DevTools (expires ~5 min)
TURNSTILE_TOKEN=
# Option B: solver service API key (capsolver.com or 2captcha.com, ~$1-2/1000 tokens)
TURNSTILE_API_KEY=
TURNSTILE_SOLVER=capsolver
# Option C: copy userKey directly from browser DevTools → verifyUser response (skips Turnstile)
PERCHANCE_USER_KEY=
